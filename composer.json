{
  "name": "hustlesmilez/re-nurture-crm",
  "type": "project",
  "description": "Real Estate CRM with contact management, pipelines, and unified communication.",
  "keywords": ["real-estate", "crm", "laravel", "nurture"],
  "license": "MIT",
  "require": {
    "php": "^8.3",
    "laravel/framework": "^11.0",
    "laravel/tinker": "^2.9",
    "livewire/livewire": "^3.0",
    "google/apiclient": "^2.15",
    "twilio/sdk": "^9.0",
    "sendgrid/sendgrid": "^7.12"
  },
  "require-dev": {
    "laravel/pint": "^1.13",
    "laravel/sail": "^1.26",
    "mockery/mockery": "^1.6",
    "nunomaduro/collision": "^8.0",
    "pestphp/pest": "^2.34",
    "pestphp/pest-plugin-laravel": "^2.34"
  },
  "autoload": {
    "psr-4": {
      "App\\": "app/",
      "Database\\Factories\\": "database/factories/",
      "Database\\Seeders\\": "database/seeders/"
    }
  },
  "config": {
    "sort-packages": true
  },
  "minimum-stability": "stable",
  "prefer-stable": true
}
